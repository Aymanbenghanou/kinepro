generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id               String              @id @default(cuid())
  email            String              @unique
  password         String
  role             String              @default("CABINET_OWNER") // SUPER_ADMIN | CABINET_OWNER | EMPLOYEE
  nom              String
  prenom           String
  telephone        String?
  twoFactorEnabled Boolean             @default(false)
  twoFactorSecret  String?
  cabinetId        String?
  cabinet          Cabinet?            @relation("CabinetUsers", fields: [cabinetId], references: [id])
  ownedCabinet     Cabinet?            @relation("CabinetOwner")
  praticienId      String?             @unique
  praticien        Praticien?          @relation(fields: [praticienId], references: [id])
  pushSubscriptions PushSubscription[]
  createdAt        DateTime            @default(now())
  lastLoginAt      DateTime?
  isActive         Boolean             @default(true)
  /// Kept in DB after the Arabic feature was reverted. Currently unused
  /// by the app code; retained so prisma db push doesn't drop the column.
  preferredLang    String              @default("fr")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  cabinetId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Subscription {
  id               String    @id @default(cuid())
  cabinetId        String    @unique
  cabinet          Cabinet   @relation(fields: [cabinetId], references: [id])
  plan             String    @default("TRIAL") // TRIAL | MONTHLY | ANNUAL | SUSPENDED
  trialEndsAt      DateTime
  currentPeriodEnd DateTime?
  price            Float?
  currency         String    @default("MAD")
  createdAt        DateTime  @default(now())
}

// ─── Cabinet ─────────────────────────────────────────────────────────────────

model CabinetSite {
  id              String        @id @default(cuid())
  cabinetId       String        @unique
  cabinet         Cabinet       @relation(fields: [cabinetId], references: [id])
  templateId      String        @default("medical")
  published       Boolean       @default(false)
  primaryColor    String        @default("#2563EB")
  secondaryColor  String        @default("#1E3A5F")
  contentFr       Json?
  contentAr       Json?
  heroImageUrl    String?
  googleMapsEmbed String?
  testimonials    Testimonial[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Testimonial {
  id            String      @id @default(cuid())
  cabinetSiteId String
  cabinetSite   CabinetSite @relation(fields: [cabinetSiteId], references: [id], onDelete: Cascade)
  patientName   String
  textFr        String      @default("")
  textAr        String      @default("")
  rating        Int         @default(5)
  createdAt     DateTime    @default(now())
}

model Cabinet {
  id               String        @id @default(cuid())
  nom              String
  adresse          String?
  ville            String?
  telephone        String?
  email            String?
  googleMapsLink   String?
  whatsappNumber   String?
  googleReviewLink String?
  ownerId          String?       @unique
  subdomain        String?       @unique
  logoUrl          String?
  publicToken      String?       @unique
  // ── Online booking ────────────────────────────────────────────
  slug             String?       @unique
  bookingEnabled   Boolean       @default(false)
  workStartTime    String        @default("08:00")
  workEndTime      String        @default("18:00")
  lunchStartTime   String        @default("12:00")
  lunchEndTime     String        @default("14:00")
  bookingMessage   String?
  workingDays      String        @default("1,2,3,4,5,6")
  // ─────────────────────────────────────────────────────────────
  owner            User?         @relation("CabinetOwner", fields: [ownerId], references: [id])
  users            User[]        @relation("CabinetUsers")
  praticiens       Praticien[]
  patients         Patient[]
  seanceTypes      SeanceType[]
  subscription     Subscription?
  site             CabinetSite?
  createdAt        DateTime      @default(now())
}

// ─── Domain models ───────────────────────────────────────────────────────────

model SeanceType {
  id           String       @id @default(cuid())
  nom          String
  description  String?
  dureeDefaut  Int          @default(45)
  tarifDefaut  Float        @default(300)
  couleur      String       @default("#2563EB")
  actif        Boolean      @default(true)
  isDefault    Boolean      @default(false)
  cabinetId    String?
  cabinet      Cabinet?     @relation(fields: [cabinetId], references: [id])
  praticienId  String?
  praticien    Praticien?   @relation(fields: [praticienId], references: [id])
  seances      Seance[]
  rendezVous   RendezVous[]
  createdAt    DateTime     @default(now())
}

model Praticien {
  id           String       @id @default(cuid())
  nom          String
  prenom       String
  specialite   String?
  telephone    String?
  email        String?
  couleur      String       @default("#2563EB")
  actif        Boolean      @default(true)
  cabinetId    String?
  cabinet      Cabinet?     @relation(fields: [cabinetId], references: [id])
  user         User?
  rendezVous   RendezVous[]
  seances      Seance[]
  seanceTypes  SeanceType[]
  createdAt    DateTime     @default(now())
}

model Patient {
  id                   String        @id @default(cuid())
  nom                  String
  prenom               String
  dateNaissance        DateTime?
  sexe                 String?
  telephone            String?
  email                String?
  adresse              String?
  ville                String?
  cin                  String?
  pathologie           String?
  antecedents          String?
  allergies            String?
  medicaments          String?
  medecinReferent      String?
  medecinTelephone     String?
  mutuelle             String?
  numeroPolice         String?
  tarifSeance          Float?
  modePaiement         String?
  nbSeancesPrescrites  Int?
  frequence            String?
  praticienAssigneId   String?
  typesSeances         String?
  objectifsTraitement  String?
  dateDebutSouhaite    DateTime?
  actif                Boolean       @default(true)
  publicToken          String?       @unique
  cabinetId            String?
  cabinet              Cabinet?      @relation(fields: [cabinetId], references: [id])
  rendezVous           RendezVous[]
  seances              Seance[]
  factures             Facture[]
  feedbacks            Feedback[]
  whatsappLogs         WhatsAppLog[]
  documents            Document[]
  exerciseProgrammes   ExerciceProgram[]
  createdAt            DateTime      @default(now())
}

model ExerciceProgram {
  id             String    @id @default(cuid())
  patientId      String
  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  seanceId       String?
  cabinetId      String?
  titre          String
  contenu        Json
  langue         String    @default("fr")
  envoyeWhatsApp Boolean   @default(false)
  dateEnvoi      DateTime?
  createdAt      DateTime  @default(now())
}

model RendezVous {
  id           String      @id @default(cuid())
  date         DateTime
  duree        Int         @default(45)
  typeSeance   String
  salle        String?
  notes        String?
  statut       String      @default("confirme")
  source       String      @default("cabinet")  // "cabinet" | "online" | "phone"
  patientNotes String?
  confirmedAt  DateTime?
  cabinetId    String?
  patientId    String
  praticienId  String
  seanceTypeId String?
  patient      Patient     @relation(fields: [patientId], references: [id])
  praticien    Praticien   @relation(fields: [praticienId], references: [id])
  seanceType   SeanceType? @relation(fields: [seanceTypeId], references: [id])
  createdAt    DateTime    @default(now())
}

model Seance {
  id                String      @id @default(cuid())
  date              DateTime
  duree             Int
  typeSeance        String
  notes             String?
  statut            String      @default("realisee")
  scorePatient      Int?
  notesInternes     String?
  feedbackEnvoye    Boolean     @default(false)
  dateFeedback      DateTime?
  douleurScore      Int?
  mobiliteScore     Int?
  forceScore        Int?
  notesProgression  String?
  seanceEndTime     DateTime?
  feedbackStatus    String?
  feedbackToken     String?   @unique
  feedbackReadyAt   DateTime?
  cabinetId         String?
  patientId         String
  praticienId       String
  seanceTypeId      String?
  patient           Patient     @relation(fields: [patientId], references: [id])
  praticien         Praticien   @relation(fields: [praticienId], references: [id])
  seanceType        SeanceType? @relation(fields: [seanceTypeId], references: [id])
  facture           Facture?
  createdAt         DateTime    @default(now())
}

model Facture {
  id           String     @id @default(cuid())
  montant      Float                      // = montant total à facturer
  montantPaye  Float      @default(0)     // cumul des paiements
  statut       String     @default("en_attente") // paye | en_attente | partielle | en_retard
  dateEmise    DateTime   @default(now())
  datePaiement DateTime?
  cabinetId    String?
  patientId    String
  seanceId     String?    @unique
  paiements    Paiement[]
  patient      Patient    @relation(fields: [patientId], references: [id])
  seance       Seance?    @relation(fields: [seanceId], references: [id])
  createdAt    DateTime   @default(now())
}

model Paiement {
  id           String   @id @default(cuid())
  factureId    String
  facture      Facture  @relation(fields: [factureId], references: [id], onDelete: Cascade)
  montant      Float
  modePaiement String   // especes | virement | cheque | carte
  datePaiement DateTime @default(now())
  notes        String?
  cabinetId    String?
  createdAt    DateTime @default(now())
}

model Feedback {
  id          String   @id @default(cuid())
  score       Int
  commentaire String?
  typeMessage String   @default("post_seance")
  cabinetId   String?
  patientId   String
  seanceId    String?
  patient     Patient  @relation(fields: [patientId], references: [id])
  createdAt   DateTime @default(now())
}

model WhatsAppLog {
  id         String   @id @default(cuid())
  type       String
  cabinetId  String?
  patientId  String
  patientNom String
  telephone  String
  message    String
  patient    Patient  @relation(fields: [patientId], references: [id])
  createdAt  DateTime @default(now())
}

model Document {
  id          String   @id @default(cuid())
  nom         String
  type        String   @default("autre")
  url         String
  size        Int?
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  cabinetId   String?
  uploadedBy  String?
  createdAt   DateTime @default(now())
}

// ─── Global system config (one row, key = "global") ──────────────────────────

model SystemConfig {
  id             String @id @default("global")
  whatsappNumber String @default("")
  rib            String @default("")
  banque         String @default("")
  titulaire      String @default("")
  prixMensuel    Float  @default(299)
  prixAnnuel     Float  @default(2499)
  updatedAt      DateTime @updatedAt
}

// ─── Bank accounts (multiple RIBs for receiving payments) ───────────────────

model BankAccount {
  id            String   @id @default(cuid())
  bankName      String
  accountHolder String
  rib           String
  iban          String?
  swift         String?
  city          String?
  isActive      Boolean  @default(true)
  isDefault     Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
